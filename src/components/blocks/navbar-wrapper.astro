---
/**
 * src/components/blocks/navbar-wrapper.astro
 * WP からカテゴリを取得して Navbar に渡すラッパー
 */
import { NavbarWithCategories } from "./navbar-with-categories";
import { getCategories } from "@/lib/wordpress";

let categories: { id: number; name: string; slug: string; count: number }[] = [];
try {
  categories = await getCategories();
} catch (e) {
  console.warn("カテゴリの取得に失敗しました", e);
}
---

<NavbarWithCategories categories={categories} client:load />