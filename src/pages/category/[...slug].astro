---
/**
 * src/pages/category/[...slug].astro
 * カテゴリ別記事一覧ページ
 */
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import {
  getCategories,
  getCategoryBySlug,
  getPosts,
  getFeaturedMedia,
  stripHtml,
  formatDate,
  type WPPost,
} from "@/lib/wordpress";

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((cat) => ({
    params: { slug: decodeURIComponent(cat.slug) },
    props: { categoryId: cat.id, categoryName: cat.name, categorySlug: cat.slug },
  }));
}

const { categoryId, categoryName } = Astro.props as {
  categoryId: number;
  categoryName: string;
  categorySlug: string;
};

// カテゴリに紐づく記事を取得
let posts: WPPost[] = [];
try {
  posts = await getPosts({ per_page: 100, categories: [categoryId] });
} catch (e) {
  console.warn("WordPress API に接続できません。", e);
}

// アイキャッチを並列取得
const featuredImages = await Promise.all(
  posts.map(async (post) => {
    if (!post.featured_media) return null;
    const media = await getFeaturedMedia(post.featured_media);
    return (
      media?.media_details?.sizes?.medium_large?.source_url ??
      media?.media_details?.sizes?.large?.source_url ??
      media?.source_url ??
      null
    );
  })
);
---

<DefaultLayout title={`カテゴリ: ${categoryName}`} description={`${categoryName}の記事一覧`}>
  <Background>
  <div class="container mx-auto max-w-6xl py-28 lg:py-32 lg:pt-44">

    <!-- ヘッダー -->
    <div class="mb-12">
      <a
        href="/blog"
        class="mb-6 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        記事一覧に戻る
      </a>
      <div class="flex items-center gap-3">
        <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">カテゴリ</span>
        <h1 class="text-3xl font-bold tracking-tight">{categoryName}</h1>
      </div>
      <p class="mt-2 text-sm text-muted-foreground">{posts.length}件の記事</p>
    </div>

    <!-- 記事グリッド -->
    {posts.length === 0 ? (
      <div class="rounded-lg border border-dashed px-8 py-20 text-center text-muted-foreground">
        <p>このカテゴリの記事はまだありません。</p>
      </div>
    ) : (
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => {
          const title = stripHtml(post.title.rendered);
          const excerpt = stripHtml(post.excerpt.rendered);
          const date = formatDate(post.date);
          const imageUrl = featuredImages[i];
          const slug = decodeURIComponent(post.slug);
          return (
            <li>
              <a
                href={`/blog/${slug}`}
                class="group flex h-full flex-col overflow-hidden rounded-xl border bg-card shadow-sm transition-shadow hover:shadow-md"
              >
                <div class="aspect-video w-full overflow-hidden bg-muted">
                  {imageUrl ? (
                    <img src={imageUrl} alt={title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-muted to-muted/60">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-muted-foreground/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                        <circle cx="9" cy="9" r="2" />
                        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <time datetime={post.date} class="mb-2 block text-xs text-muted-foreground">{date}</time>
                  <h2 class="mb-2 line-clamp-2 text-base font-semibold leading-snug tracking-tight transition-colors group-hover:text-primary">{title}</h2>
                  <p class="line-clamp-3 flex-1 text-sm text-muted-foreground">{excerpt}</p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary">
                    続きを読む
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>
  </DefaultLayout>
</BasicLayout>