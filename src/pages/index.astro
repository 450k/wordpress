---
/**
 * src/pages/index.astro
 * トップページ — Contentful
 */
import BasicLayout from "@/layouts/BasicLayout.astro";
import { getPosts, assetUrl, formatDate } from "@/lib/contentful";

const { posts } = await getPosts({ limit: 6 });
---

<BasicLayout title="My Blog" description="Contentfulをヘッドレスとして使ったAstroブログ">

  <!-- Hero -->
  <section class="relative overflow-hidden border-b bg-background py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 -z-10 [mask-image:radial-gradient(ellipse_at_top,white_30%,transparent_70%)]">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,hsl(var(--primary)/0.08),transparent)]"></div>
    </div>
    <div class="container mx-auto max-w-5xl px-4 text-center">
      <p class="mb-4 text-sm font-medium uppercase tracking-widest text-muted-foreground">Learning Javascript, TypeScript and React with Udemy</p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl">Reactの学習記録</h1>
      <p class="mx-auto max-w-xl text-lg text-muted-foreground">
        Reactに必要なJavascript, Typescript, Next.jsの学習を進めていき、その学習記録をこちらのサイトに残していきます。
      </p>
      <p>
        教材は主にUdemyの講座。そのほかに書籍やYouTube動画などを参考に学習を進めていきます。
      </p>
    </div>
  </section>

  <!-- 記事グリッド -->
  <section class="container mx-auto max-w-6xl px-4 py-20">
    <div class="mb-2 flex items-center justify-between">
      <h2 class="text-2xl font-bold tracking-tight">最新記事</h2>
      <a href="/blog" class="inline-flex items-center gap-1 text-sm font-medium text-primary underline-offset-4 hover:underline">
        すべて見る
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
    </div>

    {posts.length === 0 ? (
      <div class="rounded-lg border border-dashed px-8 py-20 text-center text-muted-foreground">
        <p class="text-lg">記事が見つかりませんでした。</p>
      </div>
    ) : (
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => {
          const imageUrl = assetUrl(post.fields.featuredImage?.fields?.file?.url ?? '');
          const date = formatDate(post.fields.publishedDate);
          return (
            <li>
              <a
                href={`/blog/${post.fields.slug}`}
                class="group flex h-full flex-col overflow-hidden rounded-xl border bg-card shadow-sm transition-shadow hover:shadow-md"
              >
                <div class="aspect-video w-full overflow-hidden bg-muted">
                  {imageUrl ? (
                    <img src={imageUrl} alt={post.fields.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-muted to-muted/60">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-muted-foreground/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                        <circle cx="9" cy="9" r="2" />
                        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <time datetime={post.fields.publishedDate} class="mb-2 block text-xs text-muted-foreground">{date}</time>
                  <h3 class="mb-2 line-clamp-2 text-base font-semibold leading-snug tracking-tight transition-colors group-hover:text-primary">{post.fields.title}</h3>
                  {post.fields.shortDescription && (
                    <p class="line-clamp-3 flex-1 text-sm text-muted-foreground">{post.fields.shortDescription}</p>
                  )}
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary">
                    続きを読む
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</BasicLayout>