---
/**
 * src/pages/blog/[...slug].astro
 * 記事詳細ページ — WordPress をヘッドレス CMS として使用
 */
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Background } from '@/components/background';
import {
  getPosts,
  getFeaturedMedia,
  getCategories,
  getTags,
  formatDate,
  type WPPost,
  type WPTerm,
} from "@/lib/wordpress";

export async function getStaticPaths() {
  const posts = await getPosts({ per_page: 100 });
  return posts.map((post) => ({
    params: { slug: decodeURIComponent(post.slug) },
    props: { post },
  }));
}

const { post } = Astro.props as { post: WPPost };

// アイキャッチ・カテゴリ・タグを並列取得
const [featuredMedia, allCategories, allTags] = await Promise.all([
  post.featured_media ? getFeaturedMedia(post.featured_media) : Promise.resolve(null),
  getCategories(),
  getTags(),
]);

const featuredImageUrl =
  featuredMedia?.media_details?.sizes?.large?.source_url ??
  featuredMedia?.source_url ??
  null;

// この記事に紐づくカテゴリ・タグだけ抽出
const postCategories: WPTerm[] = allCategories.filter((c) => post.categories.includes(c.id));
const postTags: WPTerm[] = allTags.filter((t) => post.tags.includes(t.id));

const title = post.title.rendered;
const date = formatDate(post.date);
---

<DefaultLayout title={title} description="">
  <Background>
  <article class="mx-auto max-w-3xl px-4 py-16">

    <!-- 戻るリンク -->
    <a
      href="/blog"
      class="mb-8 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      記事一覧に戻る
    </a>

    <!-- カテゴリ -->
    {postCategories.length > 0 && (
      <div class="mb-4 flex flex-wrap gap-2">
        {postCategories.map((cat) => (
          <a
            href={`/category/${decodeURIComponent(cat.slug)}`}
            class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
          >
            {cat.name}
          </a>
        ))}
      </div>
    )}

    <!-- ヘッダー -->
    <header class="mb-10">
      <time datetime={post.date} class="mb-3 block text-sm text-muted-foreground">
        {date}
      </time>
      <h1
        class="text-3xl font-bold leading-tight tracking-tight md:text-4xl"
        set:html={title}
      />

      <!-- タグ -->
      {postTags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {postTags.map((tag) => (
            <a
              href={`/tag/${decodeURIComponent(tag.slug)}`}
              class="rounded-full border px-3 py-1 text-xs text-muted-foreground transition-colors hover:border-primary hover:text-primary"
            >
              #{tag.name}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- アイキャッチ画像 -->
    {featuredImageUrl && (
      <div class="mb-10 overflow-hidden rounded-xl border">
        <img
          src={featuredImageUrl}
          alt={featuredMedia?.alt_text ?? title}
          class="w-full object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- 本文 -->
    <div
      class="prose prose-neutral dark:prose-invert max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-a:text-primary prose-a:underline-offset-4
        prose-code:rounded prose-code:bg-muted prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm
        prose-pre:rounded-xl prose-pre:border prose-pre:bg-muted
        prose-blockquote:border-l-primary prose-blockquote:text-muted-foreground
        prose-img:rounded-xl prose-img:border"
      set:html={post.content.rendered}
    />

    <!-- フッター：タグ再表示 -->
    {postTags.length > 0 && (
      <footer class="mt-16 border-t pt-8">
        <p class="mb-3 text-sm font-medium text-muted-foreground">タグ</p>
        <div class="flex flex-wrap gap-2">
          {postTags.map((tag) => (
            <a
              href={`/tag/${decodeURIComponent(tag.slug)}`}
              class="rounded-full border px-3 py-1 text-xs text-muted-foreground transition-colors hover:border-primary hover:text-primary"
            >
              #{tag.name}
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</Background>
</DefaultLayout>