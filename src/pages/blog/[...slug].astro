---
/**
 * src/pages/blog/[...slug].astro
 * 記事詳細ページ — Contentful
 */
import { documentToHtmlString } from '@contentful/rich-text-html-renderer';
import { BLOCKS, INLINES } from '@contentful/rich-text-types';
import BasicLayout from '@/layouts/BasicLayout.astro';
import { getAllSlugs, getPost, assetUrl, formatDate } from '@/lib/contentful';

export async function getStaticPaths() {
  const slugs = await getAllSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };
const post = await getPost(slug);

if (!post) return Astro.redirect('/404');

const { title, shortDescription, featuredImage, publishedDate, author, content, relatedBlogPosts } = post.fields;

const imageUrl = assetUrl(featuredImage?.fields?.file?.url ?? '');
const imageAlt = featuredImage?.fields?.title ?? title;
const authorName = author?.fields?.name ?? '';
const authorAvatarUrl = assetUrl(author?.fields?.avatar?.fields?.file?.url ?? '');
const date = formatDate(publishedDate);

// RichText → HTML
const bodyHtml = documentToHtmlString(content, {
  renderNode: {
    [BLOCKS.EMBEDDED_ASSET]: (node) => {
      const url = assetUrl(node.data?.target?.fields?.file?.url ?? '');
      const alt = node.data?.target?.fields?.title ?? '';
      if (!url) return '';
      return `<img src="${url}" alt="${alt}" class="rounded-xl border my-6 w-full" loading="lazy" />`;
    },
    [INLINES.HYPERLINK]: (node, next) => {
      const uri = node.data?.uri ?? '';
      return `<a href="${uri}" target="_blank" rel="noopener noreferrer">${next(node.content)}</a>`;
    },
  },
});
---

<BasicLayout title={title} description={shortDescription ?? ''}>
  <article class="mx-auto max-w-3xl px-4 py-16">

    <!-- 戻るリンク -->
    <a href="/blog" class="mb-8 inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
      記事一覧に戻る
    </a>

    <!-- ヘッダー -->
    <header class="mb-10">
      <time datetime={publishedDate} class="mb-3 block text-sm text-muted-foreground">{date}</time>
      <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-4xl">{title}</h1>
      {shortDescription && (
        <p class="mt-4 text-lg text-muted-foreground">{shortDescription}</p>
      )}

      <!-- 著者 -->
      {authorName && (
        <div class="mt-6 flex items-center gap-3">
          {authorAvatarUrl && (
            <img src={authorAvatarUrl} alt={authorName} class="h-9 w-9 rounded-full object-cover ring-1 ring-border" />
          )}
          <span class="text-sm font-medium">{authorName}</span>
        </div>
      )}
    </header>

    <!-- アイキャッチ -->
    {imageUrl && (
      <div class="mb-10 overflow-hidden rounded-xl border">
        <img src={imageUrl} alt={imageAlt} class="w-full object-cover" loading="eager" />
      </div>
    )}

    <!-- 本文 -->
    <div
      class="prose prose-neutral dark:prose-invert max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-a:text-primary prose-a:underline-offset-4
        prose-code:rounded prose-code:bg-muted prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm
        prose-pre:rounded-xl prose-pre:border prose-pre:bg-muted
        prose-blockquote:border-l-primary prose-blockquote:text-muted-foreground
        prose-img:rounded-xl prose-img:border"
      set:html={bodyHtml}
    />

    <!-- 関連記事 -->
    {relatedBlogPosts && relatedBlogPosts.length > 0 && (
      <footer class="mt-16 border-t pt-8">
        <p class="mb-4 text-sm font-medium text-muted-foreground">関連記事</p>
        <ul class="grid gap-4 sm:grid-cols-2">
          {relatedBlogPosts.map((related) => (
            <li>
              <a
                href={`/blog/${related.fields.slug}`}
                class="group flex gap-4 rounded-xl border p-4 transition-shadow hover:shadow-md"
              >
                {related.fields.featuredImage && (
                  <img
                    src={assetUrl(related.fields.featuredImage.fields?.file?.url ?? '')}
                    alt={related.fields.title}
                    class="h-16 w-24 flex-shrink-0 rounded-lg object-cover"
                  />
                )}
                <span class="text-sm font-medium leading-snug group-hover:text-primary transition-colors">
                  {related.fields.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </footer>
    )}
  </article>
</BasicLayout>