---
import BaseHead from "@/components/BaseHead.astro";
import { Footer } from "@/components/blocks/footer";
import NavbarWrapper from '@/components/blocks/navbar-wrapper.astro';

const { title, description } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class={`h-screen antialiased`}>
    <NavbarWrapper />
    <main>
      <section class="mx-auto px-4 py-12 lg:pt-24 lg:pb-32">
        <article class="prose-lg dark:prose-invert">
          <slot />
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
